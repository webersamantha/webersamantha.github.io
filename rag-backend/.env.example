# Required for model answers.
OPENAI_API_KEY=your_openai_api_key

# Optional settings.
OPENAI_MODEL=gpt-4.1-mini
PORT=8787
MIN_RETRIEVAL_SCORE=2.1
MIN_QUERY_TOKEN_MATCHES=2

# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=https://webersamantha.github.io,http://localhost:8080

# Path to generated corpus JSON.
CORPUS_PATH=./data/corpus.json
